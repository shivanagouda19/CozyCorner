<% layout("/layouts/boilerplate.ejs") -%>

<%
  const pending = bookingData?.pending || [];
  const confirmed = bookingData?.confirmed || [];
  const completed = bookingData?.completed || [];
  const cancelled = bookingData?.cancelled || [];
  const rejected = bookingData?.rejected || [];

  const formatDateRange = (checkIn, checkOut) => {
    if (!checkIn || !checkOut) return "Dates unavailable";
    const start = new Date(checkIn).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
    const end = new Date(checkOut).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
    return `${start} - ${end}`;
  };

  const guestName = (guest) => guest?.fullName || guest?.username || "Guest";
%>

<section class="listings-page">
  <header class="listings-page-head">
    <p class="section-kicker mb-2">Host bookings</p>
    <h1 class="section-title mb-2">Host reservation manager</h1>
    <p class="section-subtitle mb-0">Monitor incoming reservations, completed stays, and cancellations for your listings.</p>
  </header>

  <div class="booking-dashboard-grid">
    <article class="show-section">
      <h4>Pending requests</h4>
      <% if (pending.length) { %>
        <div class="booking-list-stack">
          <% pending.forEach((booking) => { %>
            <div class="booking-dashboard-card">
              <div>
                <h6 class="mb-1"><%= booking.listing?.title || "Listing unavailable" %></h6>
                <p class="mb-1"><%= formatDateRange(booking.checkIn, booking.checkOut) %></p>
                <small><%= guestName(booking.guest) %> · <%= booking.guestsCount %> guest(s)</small>
              </div>
              <div class="text-end">
                <p class="booking-total mb-1">INR <%= booking.totalPrice?.toLocaleString("en-IN") %></p>
                <span class="booking-status-badge pending d-inline-block mb-2">Pending</span>
                <form method="POST" action="/bookings/<%= booking._id %>/status?_method=PATCH" class="mb-2">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="booking[status]" value="confirmed">
                  <button class="btn btn-sm listing-btn-primary">Accept</button>
                </form>
                <form method="POST" action="/bookings/<%= booking._id %>/status?_method=PATCH">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="booking[status]" value="rejected">
                  <button class="btn btn-sm listing-btn-danger">Reject</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="mb-0 trust-empty-copy">No pending requests right now. New guest requests will appear here instantly.</p>
      <% } %>
    </article>

    <article class="show-section">
      <h4>Confirmed stays</h4>
      <% if (confirmed.length) { %>
        <div class="booking-list-stack">
          <% confirmed.forEach((booking) => { %>
            <div class="booking-dashboard-card">
              <div>
                <h6 class="mb-1"><%= booking.listing?.title || "Listing unavailable" %></h6>
                <p class="mb-1"><%= formatDateRange(booking.checkIn, booking.checkOut) %></p>
                <small><%= guestName(booking.guest) %> · <%= booking.guestsCount %> guest(s)</small>
              </div>
              <div class="text-end">
                <p class="booking-total mb-1">INR <%= booking.totalPrice?.toLocaleString("en-IN") %></p>
                <span class="booking-status-badge confirmed">Confirmed</span>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="mb-0 trust-empty-copy">No upcoming guest stays yet. Keep your listing updated to increase booking confidence.</p>
      <% } %>
    </article>

    <article class="show-section">
      <h4>Rejected requests</h4>
      <% if (rejected.length) { %>
        <div class="booking-list-stack">
          <% rejected.forEach((booking) => { %>
            <div class="booking-dashboard-card cancelled">
              <div>
                <h6 class="mb-1"><%= booking.listing?.title || "Listing unavailable" %></h6>
                <p class="mb-1"><%= formatDateRange(booking.checkIn, booking.checkOut) %></p>
                <small>Guest: <%= guestName(booking.guest) %></small>
              </div>
              <span class="booking-status-badge rejected">Rejected</span>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="mb-0 trust-empty-copy">No rejected booking requests.</p>
      <% } %>
    </article>

    <article class="show-section">
      <h4>Completed stays</h4>
      <% if (completed.length) { %>
        <div class="booking-list-stack">
          <% completed.forEach((booking) => { %>
            <div class="booking-dashboard-card">
              <div>
                <h6 class="mb-1"><%= booking.listing?.title || "Listing unavailable" %></h6>
                <p class="mb-1"><%= formatDateRange(booking.checkIn, booking.checkOut) %></p>
                <small><%= guestName(booking.guest) %></small>
              </div>
              <div class="text-end">
                <p class="booking-total mb-1">INR <%= booking.totalPrice?.toLocaleString("en-IN") %></p>
                <span class="booking-status-badge completed">Completed</span>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="mb-0 trust-empty-copy">No completed stays yet. Guest feedback and payout history will appear after each trip.</p>
      <% } %>
    </article>

    <article class="show-section">
      <h4>Cancelled</h4>
      <% if (cancelled.length) { %>
        <div class="booking-list-stack">
          <% cancelled.forEach((booking) => { %>
            <div class="booking-dashboard-card cancelled">
              <div>
                <h6 class="mb-1"><%= booking.listing?.title || "Listing unavailable" %></h6>
                <p class="mb-1"><%= formatDateRange(booking.checkIn, booking.checkOut) %></p>
                <small>Guest: <%= guestName(booking.guest) %></small>
              </div>
              <span class="booking-status-badge cancelled">Cancelled</span>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="mb-0 trust-empty-copy">No cancellations recorded. Clear policies help guests book with confidence.</p>
      <% } %>
    </article>
  </div>
</section>
