<%
    const safeSuccess = typeof success !== "undefined" ? success : [];
    const safeError = typeof error !== "undefined" ? error : [];
    const safeErr = typeof err !== "undefined" ? err : [];
%>

<% if (safeSuccess && safeSuccess.length) { %>
    <div class="custom-flash alert alert-success alert-dismissible fade show" role="alert">
        <div class="flash-body">
            <i class="fa-solid fa-circle-check flash-icon" aria-hidden="true"></i>
            <span><%= safeSuccess[0] %></span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>

<% if (safeError && safeError.length) { %>
    <div class="custom-flash alert alert-danger alert-dismissible fade show" role="alert">
        <div class="flash-body">
            <i class="fa-solid fa-triangle-exclamation flash-icon" aria-hidden="true"></i>
            <span><%= safeError[0] %></span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>

<% if (safeErr && safeErr.length) { %>
    <div class="custom-flash alert alert-danger alert-dismissible fade show" role="alert">
        <div class="flash-body">
            <i class="fa-solid fa-triangle-exclamation flash-icon" aria-hidden="true"></i>
            <span><%= safeErr[0] %></span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>