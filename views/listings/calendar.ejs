<% layout("/layouts/boilerplate.ejs") -%>

<section class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
    <div>
      <p class="text-uppercase small text-muted mb-1">Availability management</p>
      <h1 class="h4 mb-1">Listing availability calendar</h1>
      <p class="text-muted mb-0">Use date ranges to block host-unavailable periods.</p>
    </div>
    <a href="/listings/<%= listingId %>" class="btn nav-ghost-btn">Back to listing</a>
  </div>

  <div class="row g-3">
    <div class="col-12 col-lg-5">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body">
          <h2 class="h6 mb-3">Block date range</h2>
          <form method="POST" action="/listings/<%= listingId %>/block-dates">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="mb-3">
              <label class="form-label" for="block-start-date">Start date</label>
              <input id="block-start-date" name="block[startDate]" type="date" class="form-control" required>
            </div>

            <div class="mb-3">
              <label class="form-label" for="block-end-date">End date</label>
              <input id="block-end-date" name="block[endDate]" type="date" class="form-control" required>
            </div>

            <button type="submit" class="btn listing-btn-primary w-100">Save blocked range</button>
          </form>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-7">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body">
          <h2 class="h6 mb-3">Unavailable ranges</h2>

          <% if (availability?.unavailable?.length) { %>
            <div class="table-responsive">
              <table class="table table-sm align-middle mb-0">
                <thead>
                  <tr>
                    <th>Start</th>
                    <th>End</th>
                    <th>Source</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  <% availability.unavailable.forEach((range) => { %>
                    <tr>
                      <td><%= new Date(range.checkIn).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) %></td>
                      <td><%= new Date(range.checkOut).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) %></td>
                      <td><%= range.source === "manual_block" ? "Manual block" : "Booking" %></td>
                      <td><%= range.status %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p class="text-muted mb-0">No blocked or booked date ranges yet.</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>
