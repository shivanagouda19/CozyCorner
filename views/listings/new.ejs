<% layout("/layouts/boilerplate.ejs") -%>

    <div class="row">
        <div class="col-12 col-lg-10 offset-lg-1">
            <h2>Create a New Listing</h2>
            <br>
            <form method="POST" action="/listings" enctype="multipart/form-data" novalidate class="needs-validation">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input name="listing[title]" placeholder="enter title" type="text" id="title"
                        class="form-control" required/>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                            Please choose a Title.
                        </div>
                </div>
                <br />
                <div class="mb-3">
                    <label for="description" class="form-label">description</label>
                    <textarea name="listing[description]" placeholder="enter description"
                        class="form-control" required></textarea>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                            Please choose a description.
                        </div>
                </div>
                <br />
                <div class="mb-3">
                    <label for="listingImages" class="form-label">Upload Images</label>
                    <input name="listingImages" id="listingImages" type="file" accept="image/*" class="form-control" multiple />
                    <div class="form-text">You can upload up to 5 images per listing.</div>
                </div>
                <br />
                <div class="form-group">
                    <label for="category">Category</label>
                    <select name="listing[category]" required>
                        <option value="">Select Category</option>
                        <option value="villa">Villa</option>
                        <option value="apartment">Apartment</option>
                        <option value="farmhouse">Farmhouse</option>
                        <option value="room">Room</option>
                        <option value="hotel">Hotel</option>
                    </select>
                </div><br>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">price</label>
                        <input name="listing[price]" placeholder="enter price"  class="form-control" required/>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                            Please choose a price.
                        </div>
                    </div>
                    <br />
                    <div class="mb-3 col-md-8">
                        <label for="listing-country" class="form-label">country</label>
                        <input name="listing[country]" id="listing-country" placeholder="enter country" type="text" class="form-control" required/>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                            Please choose a country.
                        </div>
                    </div>
                </div>
                <br />
                <div class="mb-3">
                    <label for="listing-location" class="form-label">location</label>
                    <input name="listing[location]" id="listing-location" placeholder="enter location" type="text" class="form-control" required/>
                    <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                            Please choose a location.
                        </div>
                </div>
                <input type="hidden" name="listing[geometry][type]" id="listing-geometry-type" value="Point">
                <input type="hidden" name="listing[geometry][coordinates][0]" id="listing-lng" value="">
                <input type="hidden" name="listing[geometry][coordinates][1]" id="listing-lat" value="">

                <div class="mb-3 create-map-preview-wrapper">
                    <label class="form-label">Live Map Preview</label>
                    <div
                        id="create-listing-map"
                        class="listing-map-preview"
                        data-map-config='<%- JSON.stringify({ mapToken, fallbackZoom }) %>'
                    ></div>
                    <p id="create-map-status" class="map-status-text mt-2 mb-0">Start typing location and country to preview the map.</p>
                </div>
                <br />
                <button class="btn btn-dark d-block mx-auto add-btn">Add Listing</button>
                <br>
                <br>
            </form>
        </div>
    </div>
    <script src="/js/map/core.js"></script>
    <script src="/js/map/createMap.js"></script>
