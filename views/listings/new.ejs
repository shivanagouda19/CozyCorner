<% layout("/layouts/boilerplate.ejs") -%>

    <div class="row">
        <div class="col-12 col-lg-10 offset-lg-1">
            <h2>Create a New Listing</h2>
            <br>
            <form method="POST" action="/listings" enctype="multipart/form-data" novalidate class="needs-validation">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input name="listing[title]" placeholder="enter title" type="text" id="title"
                        class="form-control" required/>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                            Please choose a Title.
                        </div>
                </div>
                <br />
                <div class="mb-3">
                    <label for="description" class="form-label">description</label>
                    <textarea name="listing[description]" placeholder="enter description"
                        class="form-control" required></textarea>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                            Please choose a description.
                        </div>
                </div>
                <br />
                <div class="mb-3 listing-image-upload" data-image-upload data-max-images="5" data-existing-images="0" data-min-images="1">
                    <label for="listingImages" class="form-label">Upload Images</label>
                    <div class="upload-dropzone" data-upload-dropzone>
                        <input name="listingImages" id="listingImages" type="file" accept="image/*" class="upload-input" multiple required data-upload-input />
                        <div class="upload-dropzone-content">
                            <i class="fa-regular fa-images upload-dropzone-icon"></i>
                            <p class="mb-1 fw-semibold">Drag and drop images here</p>
                            <p class="mb-0 text-muted">or click to browse files</p>
                        </div>
                    </div>
                    <div class="upload-meta mt-2">
                        <span class="upload-count" data-upload-count>0 selected</span>
                        <span class="upload-limit" data-upload-limit>You can upload up to 5 images.</span>
                    </div>
                    <div class="upload-preview-grid mt-3" data-upload-preview aria-live="polite"></div>
                    <div class="invalid-feedback d-block" data-upload-error></div>
                </div>
                <br />
                <div class="form-group">
                    <label for="category">Category</label>
                    <select name="listing[category]" id="category" class="form-select" required>
                        <option value="" selected>Select Category</option>
                        <option value="villa">Villa</option>
                        <option value="apartment">Apartment</option>
                        <option value="farmhouse">Farmhouse</option>
                        <option value="room">Room</option>
                        <option value="hotel">Hotel</option>
                    </select>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">
                        Please choose a category.
                    </div>
                </div><br>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">price</label>
                        <input name="listing[price]" placeholder="enter price"  class="form-control" required/>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                            Please choose a price.
                        </div>
                    </div>
                    <br />
                    <div class="mb-3 col-md-8">
                        <label for="listing-country" class="form-label">country</label>
                        <input name="listing[country]" id="listing-country" placeholder="enter country" type="text" class="form-control" required/>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                            Please choose a country.
                        </div>
                    </div>
                </div>
                <br />
                <div class="mb-3">
                    <label for="listing-location" class="form-label">location</label>
                    <input name="listing[location]" id="listing-location" placeholder="enter location" type="text" class="form-control" required/>
                    <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                            Please choose a location.
                        </div>
                </div>
                <input type="hidden" name="listing[geometry][type]" id="listing-geometry-type" value="Point">
                <input type="hidden" name="listing[geometry][coordinates][0]" id="listing-lng" value="">
                <input type="hidden" name="listing[geometry][coordinates][1]" id="listing-lat" value="">

                <div class="mb-3 create-map-preview-wrapper">
                    <label class="form-label">Live Map Preview</label>
                    <div
                        id="create-listing-map"
                        class="listing-map-preview"
                        data-map-config='<%- JSON.stringify({ mapToken, fallbackZoom }) %>'
                    ></div>
                    <p id="create-map-status" class="map-status-text mt-2 mb-0">Start typing location and country to preview the map.</p>
                </div>
                <br />
                <button class="btn btn-dark d-block mx-auto add-btn">Add Listing</button>
                <br>
                <br>
            </form>
        </div>
    </div>
    <script src="/js/map/core.js"></script>
    <script src="/js/map/createMap.js"></script>

    <div class="modal fade" id="uploadPreviewModal" tabindex="-1" aria-labelledby="uploadPreviewModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header">
                    <h5 class="modal-title" id="uploadPreviewModalLabel">Image Preview</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">
                    <img src="" alt="Upload preview" class="img-fluid rounded" id="uploadPreviewModalImage">
                </div>
            </div>
        </div>
    </div>

