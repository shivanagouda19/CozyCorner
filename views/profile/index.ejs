<% layout("/layouts/boilerplate.ejs") -%>
<link rel="stylesheet" href="/css/profile.css">

<%
  const user = profileData?.user || {};
  const stats = profileData?.stats || { listingCount: 0, reviewsReceivedCount: 0, upcomingCount: 0 };
  const fullName = user.fullName || user.username || "Guest";
  const memberSince = user.createdAt ? new Date(user.createdAt).toLocaleString("en-US", { month: "long", year: "numeric" }) : "Unknown";
  const avatarUrl = user.avatar?.url || "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=300&h=300&fit=crop";
  const profile = user.profile || { bio: "", location: "", languages: [] };
  const languagesText = Array.isArray(profile.languages) && profile.languages.length
    ? profile.languages.join(", ")
    : "No languages added";
%>

<section class="profile-shell">
  <div class="profile-grid mt-2">
    <%- include("./includes/sidebar.ejs", { activeRoute }) %>

    <main class="profile-main">
      <section class="card-section reveal-up" data-stagger="2">
        <div class="section-head">
          <h2>Dashboard summary</h2>
          <a href="/profile/edit" class="text-link">Edit profile</a>
        </div>

        <div class="overview-top-grid">
          <article class="profile-card-left overview-identity-card">
            <img class="avatar" src="<%= avatarUrl %>" alt="Profile avatar">
            <h3 class="mt-3 mb-1"><%= fullName %></h3>
            <p class="text-muted mb-2">Member since <%= memberSince %></p>
          </article>

          <article class="summary-stats-card">
            <h4 class="mb-3">Quick stats</h4>
            <div class="stats-tiles-grid">
              <article class="stat-tile">
                <h6>Listings</h6>
                <p><%= stats.listingCount || 0 %></p>
              </article>
              <article class="stat-tile">
                <h6>Bookings</h6>
                <p><%= stats.upcomingCount || 0 %></p>
              </article>
              <article class="stat-tile">
                <h6>Reviews</h6>
                <p><%= stats.reviewsReceivedCount || 0 %></p>
              </article>
            </div>
          </article>
        </div>

        <div class="profile-info-grid mt-3">
          <article class="info-card">
            <h6>Location</h6>
            <p><%= profile.location || "Location not added" %></p>
          </article>
          <article class="info-card">
            <h6>Languages</h6>
            <p><%= languagesText %></p>
          </article>
          <article class="info-card info-card-wide">
            <h6>Bio</h6>
            <p><%= profile.bio || "No bio added yet" %></p>
          </article>
        </div>

        <div class="overview-actions-panel mt-3">
          <h5 class="mb-3">Quick actions</h5>
          <div class="quick-actions">
            <a class="btn listing-btn-primary" href="/listings/new">Add listing</a>
            <a class="btn nav-ghost-btn" href="/profile/listings">Manage listings</a>
            <a class="btn nav-ghost-btn" href="/profile/bookings">View bookings</a>
            <a class="btn nav-ghost-btn" href="/profile/reviews">Reviews</a>
            <a class="btn nav-ghost-btn" href="/profile/wishlist">Wishlist</a>
            <a class="btn nav-ghost-btn" href="/profile/settings">Settings</a>
          </div>
        </div>
      </section>
    </main>
  </div>
</section>

<script src="/js/profile.js"></script>
