<% layout("/layouts/boilerplate.ejs") -%>

<div class="row mt-4 mb-5">
	<div class="col-12 col-md-10 col-lg-8 offset-md-1 offset-lg-2">
		<h1 class="mb-3">LogIn on CozyCorner</h1>

		<form action="/login" method="POST" class="needs-validation" novalidate>
			<input type="hidden" name="_csrf" value="<%= csrfToken %>">
			<div class="mb-3">
				<label for="username" class="form-label">Username</label>
				<input
					name="username"
					id="username"
					type="text"
					class="form-control"
					required
				/>
				<div class="invalid-feedback">Please enter your username.</div>
			</div>

			<div class="mb-3">
				<label for="password" class="form-label">Password</label>
				<input
					name="password"
					id="password"
					type="password"
					class="form-control"
					required
				/>
				<div class="invalid-feedback">Please enter your password.</div>
			</div>

			<div class="mb-3">
				<a href="/forgot-password">Forgot password?</a>
			</div>

			<button type="submit" class="btn btn-success">LogIn</button>
		</form>

		<hr class="my-4" />
		<p class="mb-2">Did not receive verification email?</p>
		<form action="/resend-verification" method="POST" class="row g-2">
			<input type="hidden" name="_csrf" value="<%= csrfToken %>">
			<div class="col-12 col-md-8">
				<input
					name="identifier"
					type="text"
					class="form-control"
					placeholder="Enter username or email"
					required
				/>
			</div>
			<div class="col-12 col-md-4 d-grid">
				<button type="submit" class="btn btn-outline-secondary">Resend Verification</button>
			</div>
		</form>
	</div>
</div>
